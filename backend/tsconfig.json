{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "paths": {
            "@config/*": [
                "./src/config/*"
            ],
            "@controllers/*": [
                "./src/controllers/*"
            ],
            "@middleware/*": [
                "./src/middleware/*"
            ],
            "@routes/*": [
                "./src/routes/*"
            ],
            "@services/*": [
                "./src/services/*"
            ],
            "@appTypes/*": [
                "./src/types/*"
            ],
            "@utils/*": [
                "./src/utils/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}